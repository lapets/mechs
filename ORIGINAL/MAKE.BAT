@ECHO OFF
IF NOT "%1"=="BUILD" GOTO CLEAN_CHECK

:BUILD
@ECHO ON
LIB MAIN.LIB;
LIB MAIN.LIB+MODEXLIB.LIB;
BC MAIN.BAS/O/T/C:512;
BC GRAPHICS.BAS/O/T/C:512;
BC KEYBOARD.BAS/O/T/C:512;
BC UTIL.BAS/O/T/C:512;
BC AI.BAS/O/T/C:512;
BC MENU.BAS/O/T/C:512;
LINK /EX /NOE /NOD:BRUN45.LIB MAIN+GRAPHICS+KEYBOARD+UTIL+AI+MENU,MAIN.EXE,NUL,BCOM45.LIB MAIN.LIB;
@ECHO OFF
GOTO CLEAN

:CLEAN_CHECK
IF NOT "%1"=="CLEAN" GOTO FINISH
IF EXIST MAIN.EXE DEL MAIN.EXE

:CLEAN
IF EXIST QB.BAK DEL QB.BAK
IF EXIST MAIN.BAK DEL MAIN.BAK
IF EXIST MAIN.LIB DEL MAIN.LIB
IF EXIST MAIN.OBJ DEL MAIN.OBJ
IF EXIST GRAPHICS.OBJ DEL GRAPHICS.OBJ
IF EXIST KEYBOARD.OBJ DEL KEYBOARD.OBJ
IF EXIST UTIL.OBJ DEL UTIL.OBJ
IF EXIST AI.OBJ DEL AI.OBJ
IF EXIST MENU.OBJ DEL MENU.OBJ

:FINISH
